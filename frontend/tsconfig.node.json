{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  },
  "include": [
    "vite.config.ts",
    "playwright.config.ts",
    "tests/e2e/**/*.ts",
    "src/domain/interfaces/**/*.ts",
    "src/shared/config/**/*.ts"
  ]
}